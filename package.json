{
  "name": "soroban-dev-console-monorepo",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=web --filter=@devconsole/ui --filter=@devconsole/soroban-utils",
    "dev": "turbo run dev --filter=web",
    "lint": "turbo run lint --filter=web --filter=@devconsole/ui --filter=@devconsole/soroban-utils",
    "typecheck": "turbo run typecheck --filter=web --filter=@devconsole/ui --filter=@devconsole/soroban-utils",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "security:scan": "npx tsx scripts/secret-scan.ts",
    "security:playbooks": "npx tsx scripts/validate-playbooks.ts",
    "check-integrity": "npx tsx scripts/check-dependency-integrity.ts",
    "check-drift": "npx tsx scripts/check-runtime-drift.ts",
    "release-evidence": "npx tsx scripts/generate-release-evidence.ts"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "latest"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.5.0"
  }
}
